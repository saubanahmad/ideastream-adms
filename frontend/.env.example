# Frontend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─────────────────────────────────────────────
# Backend API URL
# This is the base URL Axios uses for all API calls.
# In development, the Vite proxy (vite.config.js) handles this,
# so you can leave this as-is.
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
